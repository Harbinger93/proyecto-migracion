---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="SomosMigrantes ComoTu | Trámites de Extranjería en España"
  description="Asesoría experta en trámites de extranjería y nacionalidad española. Más de 10 años de experiencia en Arraigo, Residencia y Reagrupación Familiar con un trato cercano y profesional."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden pt-12 pb-20 sm:pt-20 sm:pb-28 lg:pt-28 lg:pb-36 bg-gradient-to-b from-teal-50/40 via-background to-background dark:from-teal-950/10 dark:via-background dark:to-background">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">
        
        <!-- Left Column: Copy & Actions -->
        <div class="lg:col-span-7 flex flex-col gap-6 sm:gap-8 reveal active">
          
          <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-xl bg-teal-100/60 dark:bg-teal-900/30 text-teal-800 dark:text-teal-300 font-semibold text-xs sm:text-sm w-fit border border-teal-200/50 dark:border-teal-800/30 shadow-xs">
            <span class="flex h-2 w-2 rounded-xl bg-emerald-500 animate-pulse"></span>
            Asesoría de Extranjería Profesional en España
          </div>

          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight text-teal-950 dark:text-white leading-[1.1] sm:leading-tight">
            Te ayudamos con tus <br />
            <span class="text-gradient">trámites de extranjería</span>
          </h1>

          <p class="text-base sm:text-lg lg:text-xl text-muted-foreground leading-relaxed max-w-2xl">
            Más de 10 años de experiencia ayudando a regularizar tu situación en España con un trato cercano, honesto y profesional.
          </p>

          <!-- Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 sm:items-center mt-2">
            <a 
              href="https://wa.me/34600000000" 
              target="_blank" 
              rel="noopener noreferrer" 
              class="flex items-center justify-center gap-2.5 bg-teal-700 hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-700 text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-teal-500/15 hover:shadow-teal-500/25 text-base transition-all hover:scale-[1.02] active:scale-[0.98] cursor-pointer"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M.057 24l1.687-6.163c-1.041-1.804-1.588-3.849-1.587-5.946C.06 5.348 5.397.01 12.008.01c3.202.001 6.212 1.246 8.477 3.514 2.266 2.268 3.507 5.28 3.505 8.484-.004 6.657-5.34 11.997-11.953 11.997-2.005-.001-3.973-.502-5.724-1.455L0 24zm6.59-4.846c1.6.95 3.188 1.449 4.625 1.451 5.403.002 9.803-4.394 9.806-9.8.001-2.618-1.01-5.08-2.859-6.931C16.378 2.025 13.92 1.015 11.3 1.015c-5.405 0-9.809 4.404-9.813 9.813-.001 1.542.41 3.05 1.189 4.39l-1.096 4.001 4.108-1.077zm11.75-6.52c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.174.2-.298.3-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414-.074-.124-.272-.198-.57-.347z"/>
              </svg>
              WhatsApp
            </a>
            <a 
              href="tel:+34600000000" 
              class="flex items-center justify-center gap-2 border-2 border-teal-700 dark:border-teal-600 hover:bg-teal-50 dark:hover:bg-teal-950/20 text-teal-800 dark:text-teal-400 font-bold px-8 py-3.5 rounded-xl text-base transition-all hover:scale-[1.02] active:scale-[0.98] cursor-pointer"
            >
              <svg class="w-5 h-5 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
              </svg>
              Llamar ahora
            </a>
          </div>

          <!-- Badges -->
          <div class="flex flex-wrap gap-x-6 gap-y-3 items-center mt-4 text-sm font-semibold text-teal-900 dark:text-teal-300">
            <span class="flex items-center gap-1.5 shrink-0">
              <svg class="h-5 w-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Respuesta rápida
            </span>
            <span class="flex items-center gap-1.5 shrink-0">
              <svg class="h-5 w-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              Trato cercano
            </span>
            <span class="flex items-center gap-1.5 shrink-0">
              <svg class="h-5 w-5 text-emerald-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              +10 años experiencia
            </span>
          </div>

        </div>

        <!-- Right Column: Glassmorphic Visual Graphic -->
        <div class="lg:col-span-5 relative flex items-center justify-center reveal reveal-delay-200">
          
          <!-- Abstract Background Gradients -->
          <div class="absolute h-72 sm:h-96 w-72 sm:w-96 rounded-xl bg-teal-400/20 dark:bg-teal-600/10 blur-3xl -z-10 -top-8 -right-8"></div>
          <div class="absolute h-72 sm:h-96 w-72 sm:w-96 rounded-xl bg-amber-400/10 dark:bg-amber-500/5 blur-3xl -z-10 -bottom-8 -left-8"></div>

          <!-- Glassmorphic Card Cluster -->
          <div class="w-full max-w-md aspect-square rounded-2xl border border-border/40 bg-card/60 backdrop-blur-md shadow-2xl p-6 flex flex-col gap-6 relative overflow-hidden glass-card">
            
            <!-- Logo details inside graphic -->
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-xl bg-teal-800/10 dark:bg-teal-400/10 flex items-center justify-center text-teal-800 dark:text-teal-400">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
              </div>
              <div>
                <h4 class="font-bold text-sm text-teal-950 dark:text-white leading-none">Casos Gestionados</h4>
                <p class="text-xs text-muted-foreground mt-0.5">Expedientes activos 2026</p>
              </div>
            </div>

            <!-- Graph Representation -->
            <div class="flex-grow flex items-end gap-3 px-2 py-4">
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-teal-100 dark:bg-teal-900/30 rounded-lg h-24 relative flex items-end overflow-hidden">
                  <div class="w-full bg-teal-700/80 dark:bg-teal-500/80 h-[45%] rounded-b-lg"></div>
                </div>
                <span class="text-[10px] font-semibold text-muted-foreground">Arraigo</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-teal-100 dark:bg-teal-900/30 rounded-lg h-36 relative flex items-end overflow-hidden">
                  <div class="w-full bg-teal-700/80 dark:bg-teal-500/80 h-[85%] rounded-b-lg"></div>
                </div>
                <span class="text-[10px] font-semibold text-muted-foreground">Residencia</span>
              </div>
              <div class="flex-1 flex flex-col items-center gap-2">
                <div class="w-full bg-teal-100 dark:bg-teal-900/30 rounded-lg h-28 relative flex items-end overflow-hidden">
                  <div class="w-full bg-teal-700/80 dark:bg-teal-500/80 h-[65%] rounded-b-lg"></div>
                </div>
                <span class="text-[10px] font-semibold text-muted-foreground">Nacionalidad</span>
              </div>
            </div>

            <!-- Floating Overlay Card 1 -->
            <div class="absolute -bottom-3 -right-3 sm:-right-6 bg-card border border-border/80 rounded-xl shadow-xl p-4 flex items-center gap-3 animate-pulse">
              <div class="h-10 w-10 rounded-xl bg-amber-500/10 flex items-center justify-center text-amber-500 shrink-0">
                <span>🇪🇸</span>
              </div>
              <div>
                <p class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider">Éxito en Trámites</p>
                <p class="text-base font-extrabold text-teal-950 dark:text-white leading-none mt-0.5">98% Aprobados</p>
              </div>
            </div>

            <!-- Floating Overlay Card 2 -->
            <div class="absolute top-1/3 -left-3 sm:-left-6 bg-card border border-border/80 rounded-xl shadow-xl p-3 flex items-center gap-2.5">
              <div class="h-8 w-8 rounded-xl bg-emerald-500/10 flex items-center justify-center text-emerald-500 text-xs font-bold shrink-0">
                ✓
              </div>
              <div>
                <p class="text-[9px] font-bold text-muted-foreground leading-none">ÚLTIMO AVISO</p>
                <p class="text-xs font-bold text-teal-950 dark:text-white mt-0.5 leading-none">Residencia aprobada</p>
              </div>
            </div>

          </div>

        </div>

      </div>
    </div>
  </section>

  <!-- Nuestros Servicios Section -->
  <section class="py-20 sm:py-24 border-t border-border/40">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <h2 class="text-xs font-extrabold text-teal-700 dark:text-teal-400 tracking-widest uppercase mb-3">Nuestros Servicios</h2>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-teal-950 dark:text-white leading-tight">
          Te acompañamos en cada paso para regularizar tu situación
        </h3>
      </div>

      <!-- Service Card Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 sm:gap-8 reveal reveal-delay-200">
        
        <!-- Card 1 -->
        <div class="bg-card border border-border/80 hover:border-teal-700/30 dark:hover:border-teal-500/30 rounded-2xl p-6 sm:p-8 shadow-xs hover-premium-card transition-all duration-300">
          <div class="h-12 w-12 rounded-xl bg-teal-50 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 mb-6 border border-teal-100/50 dark:border-teal-900/30">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-teal-950 dark:text-white mb-3">Autorización de Residencia</h4>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6">
            Obtén tu permiso de residencia en España de forma legal y segura.
          </p>
          <a href="/tramites" class="inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-400 group-hover:underline">
            Ver detalles <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </div>

        <!-- Card 2 -->
        <div class="bg-card border border-border/80 hover:border-teal-700/30 dark:hover:border-teal-500/30 rounded-2xl p-6 sm:p-8 shadow-xs hover-premium-card transition-all duration-300">
          <div class="h-12 w-12 rounded-xl bg-teal-50 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 mb-6 border border-teal-100/50 dark:border-teal-900/30">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 21v-4m0 0V5a2 2 0 012-2h6.5l1 1H21l-3 6 3 6h-8.5l-1-1H5a2 2 0 00-2 2zm9-13.5V9" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-teal-950 dark:text-white mb-3">Nacionalidad Española</h4>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6">
            Consigue la nacionalidad española cumpliendo los requisitos necesarios.
          </p>
          <a href="/tramites" class="inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-400 group-hover:underline">
            Ver detalles <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </div>

        <!-- Card 3 -->
        <div class="bg-card border border-border/80 hover:border-teal-700/30 dark:hover:border-teal-500/30 rounded-2xl p-6 sm:p-8 shadow-xs hover-premium-card transition-all duration-300">
          <div class="h-12 w-12 rounded-xl bg-teal-50 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 mb-6 border border-teal-100/50 dark:border-teal-900/30">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-teal-950 dark:text-white mb-3">Arraigo (Social, Laboral, Familiar)</h4>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6">
            Regulariza tu situación por arraigo social, laboral o familiar.
          </p>
          <a href="/tramites" class="inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-400 group-hover:underline">
            Ver detalles <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </div>

        <!-- Card 4 -->
        <div class="bg-card border border-border/80 hover:border-teal-700/30 dark:hover:border-teal-500/30 rounded-2xl p-6 sm:p-8 shadow-xs hover-premium-card transition-all duration-300">
          <div class="h-12 w-12 rounded-xl bg-teal-50 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 mb-6 border border-teal-100/50 dark:border-teal-900/30">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-teal-950 dark:text-white mb-3">Reagrupación Familiar</h4>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6">
            Trae a tu familia contigo a España de forma legal.
          </p>
          <a href="/tramites" class="inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-400 group-hover:underline">
            Ver detalles <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </div>

        <!-- Card 5 -->
        <div class="bg-card border border-border/80 hover:border-teal-700/30 dark:hover:border-teal-500/30 rounded-2xl p-6 sm:p-8 shadow-xs hover-premium-card transition-all duration-300">
          <div class="h-12 w-12 rounded-xl bg-teal-50 dark:bg-teal-950/40 text-teal-700 dark:text-teal-400 flex items-center justify-center group-hover:scale-110 transition-transform duration-300 mb-6 border border-teal-100/50 dark:border-teal-900/30">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h4 class="text-xl font-bold text-teal-950 dark:text-white mb-3">Autorización de Trabajo</h4>
          <p class="text-sm text-muted-foreground leading-relaxed mb-6">
            Consigue permiso para trabajar legalmente en España.
          </p>
          <a href="/tramites" class="inline-flex items-center gap-1 text-sm font-semibold text-teal-700 dark:text-teal-400 group-hover:underline">
            Ver detalles <span class="group-hover:translate-x-1 transition-transform duration-200">→</span>
          </a>
        </div>

      </div>

      <!-- Action Button -->
      <div class="text-center mt-12 reveal reveal-delay-300">
        <a 
          href="/tramites" 
          class="inline-flex items-center gap-2 border-2 border-teal-700 dark:border-teal-600 hover:bg-teal-50 dark:hover:bg-teal-950/20 text-teal-800 dark:text-teal-400 font-bold px-8 py-3 rounded-xl text-base transition-all hover:scale-[1.02] active:scale-[0.98]"
        >
          Ver todos los trámites
        </a>
      </div>

    </div>
  </section>

  <!-- Section 3: Un proceso simple y claro -->
  <section class="py-20 sm:py-24 bg-teal-900/5 dark:bg-teal-950/10">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      
      <!-- Big green banner card -->
      <div class="bg-teal-800 dark:bg-teal-950/60 border border-teal-700/50 text-white rounded-3xl p-8 sm:p-12 lg:p-16 shadow-2xl relative overflow-hidden reveal">
        
        <!-- Background light sphere -->
        <div class="absolute h-96 w-96 rounded-xl bg-teal-700 dark:bg-teal-900/60 blur-3xl -z-10 -bottom-12 -right-12 opacity-50"></div>
        
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="text-xs font-bold text-teal-300 tracking-widest uppercase mb-3">Un proceso simple y claro</h2>
          <h3 class="text-3xl sm:text-4xl font-extrabold leading-tight">
            Cómo trabajamos para garantizar tu éxito
          </h3>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative z-10">
          
          <!-- Step 1 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="h-14 w-14 rounded-xl bg-teal-750 dark:bg-teal-900 border border-teal-700 flex items-center justify-center text-white shadow-lg text-lg font-bold">
              💬
            </div>
            <div>
              <h4 class="font-bold text-lg mb-1">1. Nos cuentas tu caso</h4>
              <p class="text-sm text-teal-100/70 leading-relaxed">
                Analizamos tu situación de forma personalizada.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="h-14 w-14 rounded-xl bg-teal-750 dark:bg-teal-900 border border-teal-700 flex items-center justify-center text-white shadow-lg text-lg font-bold">
              🎯
            </div>
            <div>
              <h4 class="font-bold text-lg mb-1">2. Diseñamos tu estrategia</h4>
              <p class="text-sm text-teal-100/70 leading-relaxed">
                Te indicamos la mejor vía para regularizarte.
              </p>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="h-14 w-14 rounded-xl bg-teal-750 dark:bg-teal-900 border border-teal-700 flex items-center justify-center text-white shadow-lg text-lg font-bold">
              💼
            </div>
            <div>
              <h4 class="font-bold text-lg mb-1">3. Nos encargamos del trámite</h4>
              <p class="text-sm text-teal-100/70 leading-relaxed">
                Preparamos y presentamos toda tu documentación.
              </p>
            </div>
          </div>

          <!-- Step 4 -->
          <div class="flex flex-col items-center text-center gap-4">
            <div class="h-14 w-14 rounded-xl bg-teal-750 dark:bg-teal-900 border border-teal-700 flex items-center justify-center text-white shadow-lg text-lg font-bold">
              ✅
            </div>
            <div>
              <h4 class="font-bold text-lg mb-1">4. ¡Listo!</h4>
              <p class="text-sm text-teal-100/70 leading-relaxed">
                Consigues tu residencia o nacionalidad.
              </p>
            </div>
          </div>

        </div>

      </div>

    </div>
  </section>

  <!-- Lo que dicen nuestros clientes -->
  <section class="py-20 sm:py-24 border-t border-border/40">
    <div class="container mx-auto px-4 sm:px-6 lg:px-8">
      
      <div class="text-center max-w-3xl mx-auto mb-16 reveal">
        <h2 class="text-xs font-extrabold text-teal-700 dark:text-teal-400 tracking-widest uppercase mb-3">Testimonios</h2>
        <h3 class="text-3xl sm:text-4xl font-extrabold text-teal-950 dark:text-white leading-tight">
          Lo que dicen nuestros clientes
        </h3>
        <p class="text-base text-muted-foreground mt-4">
          Más de 500 personas han confiado en nosotros
        </p>
      </div>

      <!-- Testimonial Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 reveal reveal-delay-200">
        
        <!-- Testimonial Card 1 -->
