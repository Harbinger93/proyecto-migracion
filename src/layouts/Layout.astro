---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
  description?: string;
  image?: string;
  canonicalURL?: string;
}

const {
  title = "SomosMigrantes ComoTu - Trámites de Extranjería en España",
  description = "Ayudamos a personas migrantes a regularizar su situación en España con un trato cercano, honesto y profesional. Expertos en Arraigo, Nacionalidad y Residencia.",
  image = "/og-image.jpg",
  canonicalURL = Astro.url.href
} = Astro.props;

// Current path for active menu highlight
const pathname = new URL(Astro.request.url).pathname;
const cleanPath = pathname.endsWith('/') && pathname.length > 1 ? pathname.slice(0, -1) : pathname;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="es_ES" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={image} />

    <!-- Theme Color for Mobile Browsers -->
    <meta name="theme-color" content="#006b5b" />

    <ClientRouter />

    <!-- Dark/Light Mode Inline Script to Avoid FOUC -->
    <script is:inline>
      const getThemePreference = () => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      };

      const setTheme = (theme) => {
        if (theme === 'dark') {
          document.documentElement.classList.add('dark');
        } else {
          document.documentElement.classList.remove('dark');
        }
      };

      setTheme(getThemePreference());
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen flex flex-col font-sans">
    
    <!-- Top Header / Navigation -->
    <header class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/80 backdrop-blur-md transition-all duration-300">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 h-16 sm:h-20 flex items-center justify-between">
        
        <!-- Logo -->
        <a href="/" class="flex items-center gap-2.5 group transition-transform hover:scale-[1.02] duration-200">
          <div class="h-9 w-9 sm:h-11 sm:h-11 rounded-lg bg-teal-700 dark:bg-teal-600 flex items-center justify-center shadow-lg shadow-teal-500/20 text-white font-extrabold text-lg select-none">
            <span class="group-hover:rotate-12 transition-transform duration-300">👋</span>
          </div>
          <div class="flex flex-col">
            <span class="font-extrabold text-base sm:text-lg tracking-tight text-teal-900 dark:text-teal-400 leading-none">
              SomosMigrantes
            </span>
            <span class="text-xs font-semibold text-amber-500 dark:text-amber-400 mt-0.5 tracking-wider uppercase">
              ComoTu
            </span>
          </div>
        </a>

        <!-- Desktop Navigation Menu -->
        <nav class="hidden md:flex items-center gap-1 lg:gap-2">
          <a href="/" class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${cleanPath === '/' || cleanPath === '' ? 'text-teal-700 dark:text-teal-400 bg-teal-50/60 dark:bg-teal-950/40' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>
            Inicio
          </a>
          <a href="/tramites" class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${cleanPath === '/tramites' ? 'text-teal-700 dark:text-teal-400 bg-teal-50/60 dark:bg-teal-950/40' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>
            Trámites
          </a>
          <a href="/preguntas-frecuentes" class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${cleanPath === '/preguntas-frecuentes' ? 'text-teal-700 dark:text-teal-400 bg-teal-50/60 dark:bg-teal-950/40' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>
            Preguntas frecuentes
          </a>
          <a href="/testimonios" class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${cleanPath === '/testimonios' ? 'text-teal-700 dark:text-teal-400 bg-teal-50/60 dark:bg-teal-950/40' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>
            Testimonios
          </a>
          <a href="/contacto" class={`px-3 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${cleanPath === '/contacto' ? 'text-teal-700 dark:text-teal-400 bg-teal-50/60 dark:bg-teal-950/40' : 'text-muted-foreground hover:text-foreground hover:bg-muted/50'}`}>
            Contacto
          </a>
        </nav>

        <!-- Right Side Controls (Theme, WhatsApp, Mobile Menu Trigger) -->
        <div class="flex items-center gap-3">
          
          <!-- Theme Toggle Button -->
          <button id="theme-toggle" class="p-2.5 rounded-xl border border-border bg-card text-muted-foreground hover:text-foreground hover:bg-muted/50 cursor-pointer transition-all duration-200" aria-label="Cambiar tema">
            <!-- Sun Icon (visible in dark mode) -->
            <svg class="h-4 sm:h-5 w-4 sm:w-5 hidden dark:block text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="4"/>
              <path d="M12 2v2"/>
              <path d="M12 20v2"/>
              <path d="m4.93 4.93 1.41 1.41"/>
              <path d="m17.66 17.66 1.41 1.41"/>
              <path d="M2 12h2"/>
              <path d="M20 12h2"/>
              <path d="m6.34 17.66-1.41 1.41"/>
              <path d="m19.07 4.93-1.41 1.41"/>
            </svg>
            <!-- Moon Icon (visible in dark mode) -->
            <svg class="h-4 sm:h-5 w-4 sm:w-5 block dark:hidden text-teal-800" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
            </svg>
          </button>

          <!-- WhatsApp Button -->
          <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer" class="hidden sm:flex items-center gap-2 bg-teal-700 hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-700 text-white font-semibold px-4.5 py-2.5 rounded-xl shadow-lg shadow-teal-500/10 text-sm hover:scale-[1.03] active:scale-[0.98] transition-all duration-200">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <span>WhatsApp</span>
          </a>

          <!-- Mobile Menu Toggle Button -->
          <button id="mobile-menu-toggle" class="p-2.5 md:hidden rounded-lg border border-border bg-card text-muted-foreground hover:text-foreground cursor-pointer transition-all duration-200" aria-label="Abrir menú">
            <svg class="h-5 w-5 block" id="menu-icon-open" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg class="h-5 w-5 hidden" id="menu-icon-close" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>
    </header>

    <!-- Mobile Navigation Drawer Overlay -->
    <div id="mobile-menu" class="fixed inset-0 top-16 sm:top-20 z-40 bg-background/95 backdrop-blur-md hidden md:hidden flex-col p-6 border-t border-border animate-in fade-in slide-in-from-top-4 duration-200">
      <nav class="flex flex-col gap-4 text-lg font-semibold mb-8">
        <a href="/" class={`px-4 py-3 rounded-xl transition-all ${cleanPath === '/' || cleanPath === '' ? 'text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-950/30' : 'text-muted-foreground hover:text-foreground'}`}>
          Inicio
        </a>
        <a href="/tramites" class={`px-4 py-3 rounded-xl transition-all ${cleanPath === '/tramites' ? 'text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-950/30' : 'text-muted-foreground hover:text-foreground'}`}>
          Trámites
        </a>
        <a href="/preguntas-frecuentes" class={`px-4 py-3 rounded-xl transition-all ${cleanPath === '/preguntas-frecuentes' ? 'text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-950/30' : 'text-muted-foreground hover:text-foreground'}`}>
          Preguntas frecuentes
        </a>
        <a href="/testimonios" class={`px-4 py-3 rounded-xl transition-all ${cleanPath === '/testimonios' ? 'text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-950/30' : 'text-muted-foreground hover:text-foreground'}`}>
          Testimonios
        </a>
        <a href="/contacto" class={`px-4 py-3 rounded-xl transition-all ${cleanPath === '/contacto' ? 'text-teal-700 dark:text-teal-400 bg-teal-50 dark:bg-teal-950/30' : 'text-muted-foreground hover:text-foreground'}`}>
          Contacto
        </a>
      </nav>
      <div class="mt-auto flex flex-col gap-4">
        <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer" class="flex items-center justify-center gap-3 bg-teal-700 dark:bg-teal-600 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-teal-500/10 hover:bg-teal-800 transition-all text-base">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          <span>Escríbenos por WhatsApp</span>
        </a>
      </div>
    </div>

    <!-- Main Content Slot -->
    <main class="flex-grow">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-teal-950 text-teal-100 border-t border-teal-900/60 transition-colors duration-300">
      <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12 sm:py-16">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
          
          <!-- Logo & Bio -->
          <div class="flex flex-col gap-4">
            <a href="/" class="flex items-center gap-2 group w-fit">
              <div class="h-9 w-9 rounded-lg bg-teal-800 flex items-center justify-center text-white font-extrabold text-base">
                <span>👋</span>
              </div>
              <div class="flex flex-col">
                <span class="font-bold text-base tracking-tight text-white leading-none">SomosMigrantes</span>
                <span class="text-[10px] font-bold text-amber-400 mt-0.5 tracking-wider uppercase">ComoTu</span>
              </div>
            </a>
            <p class="text-sm text-teal-200/70 leading-relaxed max-w-sm">
              Ayudamos a personas migrantes a regularizar su situación en España con un trato cercano, honesto y profesional. Tu éxito es nuestro objetivo.
            </p>
          </div>

          <!-- Quick Links -->
          <div class="flex flex-col gap-4">
            <h3 class="text-sm font-bold text-white tracking-wider uppercase">Enlaces rápidos</h3>
            <ul class="flex flex-col gap-2.5 text-sm">
              <li>
                <a href="/tramites" class="text-teal-200/70 hover:text-white hover:underline transition-colors">Trámites</a>
              </li>
              <li>
                <a href="/preguntas-frecuentes" class="text-teal-200/70 hover:text-white hover:underline transition-colors">Preguntas frecuentes</a>
              </li>
              <li>
                <a href="/testimonios" class="text-teal-200/70 hover:text-white hover:underline transition-colors">Testimonios</a>
              </li>
              <li>
                <a href="/contacto" class="text-teal-200/70 hover:text-white hover:underline transition-colors">Contacto</a>
              </li>
            </ul>
          </div>

          <!-- Contact Info -->
          <div class="flex flex-col gap-4">
            <h3 class="text-sm font-bold text-white tracking-wider uppercase">Contacto</h3>
            <ul class="flex flex-col gap-3 text-sm">
              <li class="flex items-center gap-2 text-teal-200/70">
                <svg class="h-4 w-4 shrink-0 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1 1 0 01-.321.988l-1.305.98a10.582 10.582 0 004.872 4.872l.98-1.305a1 1 0 01.988-.321l2.2.548a1 1 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
                <span>+34 600 000 000</span>
              </li>
              <li class="flex items-center gap-2 text-teal-200/70">
                <svg class="h-4 w-4 shrink-0 text-amber-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
                <a href="mailto:info@somosmigrantes.com" class="hover:text-white hover:underline transition-colors">info@somosmigrantes.com</a>
              </li>
              <li class="flex items-start gap-2 text-teal-200/70">
                <svg class="h-4 w-4 shrink-0 text-amber-400 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>Calle Ejemplo 123, 28001 Madrid</span>
              </li>
            </ul>
          </div>

          <!-- Socials -->
          <div class="flex flex-col gap-4">
            <h3 class="text-sm font-bold text-white tracking-wider uppercase">Síguenos</h3>
            <div class="flex items-center gap-3">
              <a href="#" class="h-10 w-10 rounded-xl border border-teal-800 bg-teal-900/40 hover:bg-teal-800 flex items-center justify-center text-teal-200 hover:text-white transition-all hover:scale-105 duration-200" aria-label="Facebook">

              <a href="#" class="h-10 w-10 rounded-xl border border-teal-800 bg-teal-900/40 hover:bg-teal-800 flex items-center justify-center text-teal-200 hover:text-white transition-all hover:scale-105 duration-200" aria-label="Instagram">

              <a href="#" class="h-10 w-10 rounded-xl border border-teal-800 bg-teal-900/40 hover:bg-teal-800 flex items-center justify-center text-teal-200 hover:text-white transition-all hover:scale-105 duration-200" aria-label="LinkedIn">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.779-1.75-1.75s.784-1.75 1.75-1.75 1.75.779 1.75 1.75-.784 1.75-1.75 1.75zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
              </a>
            </div>
          </div>

        </div>

        <hr class="my-8 border-teal-900" />

        <div class="flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-teal-200/50">
          <span>&copy; 2026 SomosMigrantes ComoTu. Todos los derechos reservados.</span>
          <div class="flex items-center gap-4">
            <a href="#" class="hover:text-white transition-colors">Política de privacidad</a>
            <a href="#" class="hover:text-white transition-colors">Términos y condiciones</a>
          </div>
        </div>

      </div>
    </footer>

    <!-- Fixed Floating WhatsApp Button -->
    <a href="https://wa.me/34600000000" target="_blank" rel="noopener noreferrer" class="fixed bottom-6 right-6 z-40 bg-[#25D366] hover:bg-[#20ba5a] text-white p-3.5 rounded-xl shadow-2xl hover:scale-110 active:scale-95 transition-all duration-300 animate-bounce group" aria-label="Escríbenos por WhatsApp">
      <svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
      </svg>
      <span class="absolute right-full mr-3 top-1/2 -translate-y-1/2 bg-teal-900 text-white font-semibold text-xs px-3 py-1.5 rounded-lg border border-teal-800 shadow-xl opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none whitespace-nowrap">
        ¿En qué podemos ayudarte?
      </span>
    </a>

    <!-- Navigation Menu Toggle Drawer & Reveal Observer Logic (Client Side) -->
    <script>
      const setupHeaderLogic = () => {
        const toggleBtn = document.getElementById('mobile-menu-toggle');
        const menu = document.getElementById('mobile-menu');
        const openIcon = document.getElementById('menu-icon-open');
        const closeIcon = document.getElementById('menu-icon-close');

        if (toggleBtn && menu && openIcon && closeIcon) {
          // Reset state first to ensure consistency on page navigation
          menu.classList.add('hidden');
          menu.classList.remove('flex');
          openIcon.classList.remove('hidden');
          closeIcon.classList.add('hidden');

          toggleBtn.addEventListener('click', () => {
            const isHidden = menu.classList.contains('hidden');
            if (isHidden) {
              menu.classList.remove('hidden');
              menu.classList.add('flex');
              openIcon.classList.add('hidden');
              closeIcon.classList.remove('hidden');
            } else {
              menu.classList.add('hidden');
              menu.classList.remove('flex');
              openIcon.classList.remove('hidden');
              closeIcon.classList.add('hidden');
            }
          });
        }

        // Theme Switch Logic
        const themeBtn = document.getElementById('theme-toggle');
        if (themeBtn) {
          themeBtn.addEventListener('click', () => {
            const isDark = document.documentElement.classList.contains('dark');
            const newTheme = isDark ? 'light' : 'dark';
            
            if (newTheme === 'dark') {
              document.documentElement.classList.add('dark');
            } else {
              document.documentElement.classList.remove('dark');
            }
            
            localStorage.setItem('theme', newTheme);
          });
        }
      };

      const setupRevealObserver = () => {
        const reveals = document.querySelectorAll('.reveal');
        
        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              entry.target.classList.add('active');
              observer.unobserve(entry.target);
            }
          });
        }, {
          threshold: 0.05,
          rootMargin: "0px 0px -50px 0px"
        });

        reveals.forEach(el => observer.observe(el));
      };

      // Run on initial load
      setupHeaderLogic();
      setupRevealObserver();

      // Re-run after View Transitions navigation
      document.addEventListener('astro:after-swap', () => {
        setupHeaderLogic();
        setupRevealObserver();
      });
    </script>
  </body>
</html>